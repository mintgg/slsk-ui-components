{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    ".next/**",
    ".source/**",
    "node_modules/**",
    "out/**",
    "build/**",
    "dist/**",
    "next-env.d.ts"
  ],
  "plugins": ["typescript", "react", "react-hooks", "nextjs"],
  "rules": {
    "no-console": "off"
  }
}
